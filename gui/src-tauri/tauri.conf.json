{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Argos",
  "version": "0.1.0",
  "identifier": "org.argos.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Argos",
        "width": 1320,
        "height": 880,
        "minWidth": 780,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: asset: http://asset.localhost; font-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
