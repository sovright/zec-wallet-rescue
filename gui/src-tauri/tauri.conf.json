{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZECK",
  "version": "0.1.0",
  "identifier": "org.zeck.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "ZECK",
        "width": 1180,
        "height": 860,
        "minWidth": 940,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: asset: http://asset.localhost; font-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
